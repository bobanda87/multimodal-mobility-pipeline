# S3 Configuration
# AWS credentials (required for S3 upload)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-north-1

# S3 Bucket name
S3_BUCKET_NAME=your_bucket_name

# S3 path for normalized Parquet files (date-partitioned, e.g. normalized/2025-12-20/)
S3_PARQUET_PATH=normalized

# Vegvesen API credentials
VEGVESEN_USER=your_vegvesen_username
VEGVESEN_PASS=your_vegvesen_password

# Oslo Bysykkel client identifier
BYSYKKEL_CLIENT=your_client_id
